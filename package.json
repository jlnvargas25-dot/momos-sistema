{
  "name": "momos-ops",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test src/lib/*.test.js",
    "test:performance": "node --test src/performance/*.test.js",
    "ci:contracts": "node scripts/verify-repository-contracts.mjs",
    "ci:quality": "npm run ci:contracts && npm test && npm run test:performance && npm run build && npm run perf:budget && npm audit --omit=dev --audit-level=high",
    "perf:budget": "node scripts/performance-budget.mjs --enforce",
    "perf:budget:report": "node scripts/performance-budget.mjs",
    "test:voice": "node --test src/lib/kitchen-voice.test.js",
    "test:workflow": "node --test src/lib/order-workflow.test.js",
    "worker:higgsfield": "node scripts/higgsfield-worker.mjs",
    "worker:higgsfield:once": "node scripts/higgsfield-worker.mjs --once",
    "worker:higgsfield:health": "node scripts/higgsfield-worker.mjs --once --health-only",
    "worker:kling": "node scripts/kling-worker.mjs",
    "worker:kling:once": "node scripts/kling-worker.mjs --once",
    "worker:kling:health": "node scripts/kling-worker.mjs --once --health-only",
    "worker:meta": "node scripts/meta-worker.mjs",
    "worker:meta:once": "node scripts/meta-worker.mjs --once",
    "worker:meta:health": "node scripts/meta-worker.mjs --once --health-only",
    "worker:postproduction": "node scripts/postproduction-worker.mjs",
    "worker:postproduction:once": "node scripts/postproduction-worker.mjs --once",
    "worker:postproduction:health": "node scripts/postproduction-worker.mjs --once --health-only",
    "worker:health": "node scripts/operational-health-worker.mjs",
    "worker:health:once": "node scripts/operational-health-worker.mjs --once",
    "worker:health:check": "node scripts/operational-health-worker.mjs --once --health-only",
    "worker:continuity:observe": "node scripts/continuity-backup-worker.mjs",
    "mcp:agency": "node scripts/momos-agency-mcp.mjs",
    "mcp:agency:health": "node scripts/momos-agency-mcp.mjs --self-test",
    "test:resilience:synthetic": "node scripts/operational-resilience-runner.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.110.2",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.9",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.9",
    "vite": "^6.2.0"
  }
}
